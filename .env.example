# Audio device names as seen by PortAudio/sounddevice
# Run: python3 -c "import sounddevice; print(sounddevice.query_devices())"
# Use a unique substring of the device name shown in that list.
# Hardware ports are pinned by udev rule (see scripts/setup_udev.sh):
#   port 2.4 (C-Media USB PnP)  -> English card
#   port 2.3 (TI PCM2902 CODEC) -> Chinese card
SOUND_CARD_EN=USB PnP Sound Device
SOUND_CARD_ZH=USB Audio CODEC
SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# STT (faster-whisper)
# Models: tiny, base, small, medium, large-v3
# larger = more accurate, slower
WHISPER_MODEL=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Translation model cache dir
TRANSLATION_MODELS_DIR=./models/translation

# TTS (piper-tts)
# Download voices via scripts/download_models.sh
PIPER_VOICE_EN=en_US-lessac-medium
PIPER_VOICE_ZH=zh_CN-huayan-medium
PIPER_MODELS_DIR=./models/piper

# Push-to-talk keys (keyboard mode)
KEY_RECORD_EN=1
KEY_RECORD_ZH=2
