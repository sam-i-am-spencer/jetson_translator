# Audio devices — PortAudio device name substrings
# Run: python3 -c "import sounddevice; print(sounddevice.query_devices())"
MIC_EN=Blue Snowball           # English mic input (Blue Snowball iCE, port 2.1)
MIC_ZH=USB PnP Sound Device   # Chinese mic input (C-Media mic jack, port 2.4)
OUT_EN=USB PnP Sound Device   # English speaker output (C-Media headphone jack, port 2.4)
OUT_ZH=USB Audio CODEC        # Chinese speaker output (TI CODEC, port 2.3)
SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# STT (faster-whisper)
# Models: tiny, base, small, medium, large-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_MODELS_DIR=./models/whisper

# Translation (Claude API)
ANTHROPIC_API_KEY=your_key_here

# TTS
# English: piper (local)
PIPER_VOICE_EN=en_US-lessac-medium
PIPER_MODELS_DIR=./models/piper
# Chinese: Azure Neural TTS
AZURE_TTS_KEY=your_key_here
AZURE_TTS_REGION=australiaeast
AZURE_VOICE_ZH=zh-TW-HsiaoChenNeural

# Push-to-talk keys (keyboard mode)
KEY_RECORD_EN=1
KEY_RECORD_ZH=2
