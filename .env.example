# Audio device names — uses persistent ALSA names set by udev rule
# (see scripts/setup_udev.sh to install the rule)
# After rule is applied and cards are replugged:
#   port 2.4 (C-Media USB PnP)   -> translator_en
#   port 2.3 (TI PCM2902 CODEC)  -> translator_zh
# plughw: prefix lets ALSA resample (hardware native rate is 44100/48000 Hz)
SOUND_CARD_EN=plughw:translator_en,0
SOUND_CARD_ZH=plughw:translator_zh,0
SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# STT (faster-whisper)
# Models: tiny, base, small, medium, large-v3
# larger = more accurate, slower
WHISPER_MODEL=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Translation model cache dir
TRANSLATION_MODELS_DIR=./models/translation

# TTS (piper-tts)
# Download voices via scripts/download_models.sh
PIPER_VOICE_EN=en_US-lessac-medium
PIPER_VOICE_ZH=zh_CN-huayan-medium
PIPER_MODELS_DIR=./models/piper

# Push-to-talk keys (keyboard mode)
KEY_RECORD_EN=1
KEY_RECORD_ZH=2
